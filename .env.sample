# Fichier d'exemple pour les variables d'environnement
# Copier ce fichier en .env et personnalise les valeurs

# ========== Configuration Node.js ==========
NODE_ENV=production
PORT=3000

# ========== Configuration MongoDB ==========
MONGODB_URI=mongodb://mongo:27017/moneytalks

# ========== Configuration Email (MailHog) ==========
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_SECURE=false
EMAIL_FROM=noreply@moneytalks.com
EMAIL_RESET_PASSWORD_URL=http://localhost:3000/reset-password

# ========== Configuration JWT (À CHANGER EN PRODUCTION) ==========
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=86400
JWT_VERIFICATION_TOKEN_SECRET=change-me-verification-secret
